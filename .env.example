# Copie para .env e ajuste.

# MVP sem custo de API
LLM_MODE=mock

# --- OpenAI em nuvem (api.openai.com) ---
# LLM_MODE=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Azure OpenAI (recurso *.openai.azure.com) ---
# A chave do portal Azure NÃO funciona como OPENAI_API_KEY na API pública.
# LLM_MODE=openai
# OPENAI_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://SEU-RECURSO.openai.azure.com
# AZURE_OPENAI_API_KEY=  (cole a Key 1 ou Key 2 do portal, sem prefixo tipo "sua-" ou texto extra)
# Nome do deployment criado no Azure AI Studio (visão / multimodal, ex.: gpt-4o)
# AZURE_OPENAI_DEPLOYMENT=nome-do-deployment
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Forçar API pública mesmo com variáveis Azure no ambiente:
# OPENAI_PROVIDER=openai

# --- Finnhub (Monitor ao vivo — notícias e sentimento) ---
# Crie uma conta gratuita em https://finnhub.io e gere sua chave:
# FINNHUB_API_KEY=sua_chave_finnhub_aqui

# Opcional
# SECRET_KEY=uma-chave-longa-aleatoria
# PORT=5000
